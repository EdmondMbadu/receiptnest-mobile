# Copy this file to .env.production and fill in real values.
# .env.production is gitignored.
#
# Used by:
#   scripts/build_ios_appstore.sh

# RevenueCat iOS public SDK key (starts with appl_).
# Project Settings -> API keys -> App-specific public SDK key for iOS.
REVENUECAT_IOS_API_KEY=appl_xxxxxxxxxxxxxxxxxxxxxxxx

# Optional: pin a specific RevenueCat offering. Defaults to the project's "current" offering.
REVENUECAT_IOS_OFFERING_ID=default_ios

# Optional: override the entitlement id used to gate Pro access. Defaults to "pro".
# REVENUECAT_PRO_ENTITLEMENT_ID=pro

# Optional: pin specific package identifiers if auto-detection is wrong.
# REVENUECAT_IOS_MONTHLY_PACKAGE_ID=$rc_monthly
# REVENUECAT_IOS_ANNUAL_PACKAGE_ID=$rc_annual
